# ── API ───────────────────────────────────────────
PORT=3000

# ── PostgreSQL / Neon ─────────────────────────────
# URL de conexão pooler (usada pela aplicação em runtime)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# URL direta (usada pelo Prisma para migrations — sem pooler)
DIRECT_URL=postgresql://user:password@host-direct/dbname?sslmode=require

# ── Autenticação ──────────────────────────────────
# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
# Credenciais do admin (único usuário do sistema)
ADMIN_USER=admin
ADMIN_PASSWORD=troque_esta_senha_admin

# ── Job de coleta ─────────────────────────────────
COLETA_MUNICIPIO=Teixeira de Freitas
COLETA_CRON=0 * * * *
COLETA_ATIVO=true
