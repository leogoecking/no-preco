{
  "name": "no-preco-api",
  "version": "1.0.0",
  "description": "API Node.js com Express e TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "LD_LIBRARY_PATH=/tmp/chrome-libs/usr/lib/x86_64-linux-gnu:/tmp/chrome-libs/lib/x86_64-linux-gnu:$LD_LIBRARY_PATH ts-node-dev --respawn --transpile-only src/server.ts",
    "dev:all": "concurrently --names \"api,web\" --prefix-colors \"blue,green\" \"npm run dev\" \"npm run dev --prefix frontend\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "worker": "ts-node-dev --respawn --transpile-only src/jobs/worker.scheduler.ts",
    "cron:teste": "ts-node-dev --respawn --transpile-only src/jobs/cron-teste.ts",
    "backfill:cidade": "ts-node --transpile-only src/scripts/backfill-cidade.ts",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "puppeteer": "^24.41.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^30.3.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.4.9",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
