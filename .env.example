# ── API ───────────────────────────────────────────
PORT=3000

# ── MongoDB (credenciais) ─────────────────────────
# Usuário root do MongoDB (acesso administrativo)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=troque_esta_senha_root

# Usuário da aplicação (acesso restrito ao banco no-preco)
MONGO_APP_USER=no_preco_user
MONGO_APP_PASSWORD=troque_esta_senha_app

# Nome do banco de dados
MONGO_DB=no-preco

# Porta do MongoDB exposta no host (opcional, padrão 27017)
MONGO_PORT=27017

# URI de conexão — usada fora do Docker com o Mongo do Compose
MONGODB_URI=mongodb://no_preco_user:troque_esta_senha_app@localhost:27017/no-preco?authSource=no-preco

# ── Autenticação ──────────────────────────────────
# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
# Credenciais do admin (único usuário do sistema)
ADMIN_USER=admin
ADMIN_PASSWORD=troque_esta_senha_admin

# ── Job de coleta ─────────────────────────────────
COLETA_MUNICIPIO=Teixeira de Freitas
COLETA_CRON=0 * * * *
COLETA_ATIVO=true
