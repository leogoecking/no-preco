# ── API ───────────────────────────────────────────
PORT=3000

# ── MongoDB (credenciais) ─────────────────────────
# Usuário root do MongoDB (acesso administrativo)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=troque_esta_senha_root

# Usuário da aplicação (acesso restrito ao banco no-preco)
MONGO_APP_USER=no_preco_user
MONGO_APP_PASSWORD=troque_esta_senha_app

# Nome do banco de dados
MONGO_DB=no-preco

# Porta do MongoDB exposta no host (opcional, padrão 27017)
MONGO_PORT=27017

# URI de conexão — usada fora do Docker (dev local sem compose)
MONGODB_URI=mongodb://localhost:27017/no-preco

# ── Job de coleta ─────────────────────────────────
COLETA_MUNICIPIO=Salvador
COLETA_CRON=0 * * * *
COLETA_ATIVO=true
